APP_NAME="Error Dashboard"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://errors.test
# Keep APP_TIMEZONE=UTC — the MySQL connection pins session TZ to UTC too.
# Renderers (Filament ->since() / ->diffForHumans) operate on Carbon diffs, so UTC everywhere works regardless of the server's system TZ.
APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Docker Compose
COMPOSE_PROJECT_NAME=errors
APP_DOMAIN=errors.test

# Database
DB_CONNECTION=mysql
DB_HOST=errors_mysql
DB_PORT=3306
DB_DATABASE=errors
DB_USERNAME=errors
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Queue: database driver (no Redis on the target VPS)
QUEUE_CONNECTION=database

# Cache: database driver (no Redis)
CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=errors_redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail: Mailpit for local dev
MAIL_MAILER=smtp
MAIL_HOST=errors_mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@errors.test"
MAIL_FROM_NAME="${APP_NAME}"

# Trust reverse proxy so Laravel emits https:// URLs.
# Set to '*' in local dev; narrow to your proxy IP range in production.
TRUSTED_PROXIES=*

# Admin user seeded into database by DatabaseSeeder
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password
ADMIN_NAME="Admin"

# Telegram alerting (optional)
TELEGRAM_BOT_TOKEN=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
